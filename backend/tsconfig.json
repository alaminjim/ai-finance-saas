{
  "compilerOptions": {
    "target": "es2021",

    "module": "commonjs",
    "rootDir": "./src",
    "moduleResolution": "node16",
    "typeRoots": ["./node_modules/@types"],

    "outDir": "./dist",

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/@types/**/*.ts"],
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts"]
}
